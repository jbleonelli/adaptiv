# Sanity CMS — copy this file to .env.local and fill in real values
# Find your project ID at https://www.sanity.io/manage

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
NEXT_PUBLIC_SANITY_STUDIO_URL=/studio

# Server-only — generate at https://www.sanity.io/manage > API > Tokens (Viewer role is enough)
SANITY_API_READ_TOKEN=

# Server-only — Editor or higher token, only needed when running the one-shot
# `npm run seed:sanity` script that uploads default content + images.
SANITY_API_WRITE_TOKEN=

# Server-only — any random string; used to authenticate Sanity webhook -> /api/revalidate
SANITY_REVALIDATE_SECRET=
